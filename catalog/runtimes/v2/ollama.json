{
  "id": "runtime:ollama",
  "kind": "runtime",
  "name": "Ollama",
  "version": "0.5.4",
  "delivery": "remote",
  "install": {
    "source": "download",
    "platforms": {
      "darwin-arm64": {
        "url": "https://github.com/ollama/ollama/releases/download/v0.5.4/ollama-darwin",
        "checksum": {
          "algo": "sha256",
          "value": "5f745eafb59ecef40cf453bedd58f9bccc0cfd79bf752514e89f4288188de319"
        },
        "extract": {
          "type": "raw"
        }
      },
      "darwin-x64": {
        "url": "https://github.com/ollama/ollama/releases/download/v0.5.4/ollama-darwin",
        "checksum": {
          "algo": "sha256",
          "value": "5f745eafb59ecef40cf453bedd58f9bccc0cfd79bf752514e89f4288188de319"
        },
        "extract": {
          "type": "raw"
        }
      },
      "linux-x64": {
        "url": "https://github.com/ollama/ollama/releases/download/v0.5.4/ollama-linux-amd64.tgz",
        "checksum": {
          "algo": "sha256",
          "value": "5f44dc7f21c4f0050c4da6649bf1501707e782b57a3f5e899e4fd0e2ffc183cb"
        },
        "extract": {
          "type": "tar.gz"
        }
      },
      "linux-arm64": {
        "url": "https://github.com/ollama/ollama/releases/download/v0.5.4/ollama-linux-arm64.tgz",
        "checksum": {
          "algo": "sha256",
          "value": "7ff1f8b2c08f5172b8e4646abdbdc3b6947f20ca7f0e9060bf07064241420d45"
        },
        "extract": {
          "type": "tar.gz"
        }
      }
    }
  },
  "bins": [
    "ollama"
  ],
  "aliases": [
    "agent:ollama",
    "binary:ollama"
  ],
  "detect": {
    "command": "ollama --version",
    "expectExitCode": 0
  },
  "installHints": {
    "brew": "brew install --cask ollama",
    "manual": "Download Ollama for macOS from https://ollama.com/download. Start the server before using OpenAI-compatible local endpoints."
  },
  "meta": {
    "description": "Run local LLMs and embedding models (Llama, Mistral, Phi, nomic-embed-text)",
    "category": "model-runtime",
    "tags": [
      "llm",
      "local",
      "inference",
      "embeddings",
      "ai"
    ],
    "homepage": "https://ollama.com",
    "docs": "https://docs.ollama.com/",
    "openaiCompatibilityDocs": "https://docs.ollama.com/openai",
    "localLlm": {
      "providerFamily": "openai_compatible",
      "openaiCompatible": true,
      "defaultBaseUrl": "http://localhost:11434/v1",
      "dockerHostBaseUrl": "http://host.docker.internal:11434/v1",
      "apiKeyPolicy": "placeholder-accepted",
      "placeholderApiKey": "ollama",
      "modelsEndpoint": "/models",
      "chatEndpoint": "/chat/completions",
      "targets": {
        "mac_host": {
          "runtimeBaseUrl": "http://localhost:11434/v1",
          "consumerUrls": {
            "host_process": "http://localhost:11434/v1",
            "docker_container": "http://host.docker.internal:11434/v1"
          },
          "healthCheck": {
            "method": "GET",
            "path": "/models"
          },
          "apiKeyPolicy": "placeholder",
          "placeholderApiKey": "ollama"
        }
      },
      "consumers": {
        "content-engine": {
          "defaultConsumerContext": "docker_container",
          "env": {
            "ENABLE_LLM": "true",
            "ENABLE_LOCAL_LLM": "true",
            "LOCAL_LLM_PROVIDER": "local",
            "LOCAL_LLM_BASE_URL": "{{baseUrl}}",
            "LOCAL_LLM_API_KEY": "{{apiKey}}",
            "LOCAL_LLM_MODEL": "{{model}}"
          }
        }
      },
      "recommendedUse": [
        "summarization",
        "tagging",
        "claims",
        "classification",
        "embeddings"
      ],
      "consumerEnv": {
        "contentEngine": {
          "ENABLE_LLM": "true",
          "ENABLE_LOCAL_LLM": "true",
          "LOCAL_LLM_PROVIDER": "local",
          "LOCAL_LLM_BASE_URL": "http://host.docker.internal:11434/v1",
          "LOCAL_LLM_API_KEY": "ollama",
          "LOCAL_LLM_MODEL": "<model-tag>"
        }
      },
      "smokeChecks": [
        {
          "name": "binary",
          "command": "ollama --version"
        },
        {
          "name": "host-openai-models",
          "command": "curl http://localhost:11434/v1/models"
        },
        {
          "name": "docker-host-openai-models",
          "command": "docker run --rm curlimages/curl:latest http://host.docker.internal:11434/v1/models"
        }
      ],
      "models": {
        "chat": [
          {
            "tag": "qwen2.5:3b",
            "workloads": [
              "summarization",
              "tagging",
              "classification"
            ],
            "minimumMemoryGb": 8,
            "status": "candidate",
            "notes": "Verify the current Ollama model tag before committing as the default."
          },
          {
            "tag": "qwen2.5:7b",
            "workloads": [
              "summarization",
              "tagging",
              "claims",
              "classification"
            ],
            "minimumMemoryGb": 16,
            "status": "candidate",
            "notes": "Verify the current Ollama model tag before committing as the default."
          },
          {
            "tag": "llama3.2:3b",
            "workloads": [
              "summarization",
              "tagging",
              "classification"
            ],
            "minimumMemoryGb": 8,
            "status": "candidate"
          }
        ],
        "embeddings": [
          {
            "tag": "nomic-embed-text",
            "workloads": [
              "embeddings"
            ],
            "minimumMemoryGb": 8,
            "status": "candidate"
          }
        ]
      },
      "securityNotes": [
        "Prefer a host-local runtime bind for development.",
        "Binding Ollama to 0.0.0.0 can expose the model runtime on the LAN; use firewall or trusted-network controls.",
        "Consumer apps should not log prompts, completions, API keys, or full provider errors."
      ]
    }
  }
}
