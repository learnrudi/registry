{
  "id": "binary:chromium",
  "name": "Chromium",
  "version": "131",
  "description": "Chromium browser for local rendering and automation",
  "category": "utilities",
  "installType": "system",
  "managed": false,
  "binary": "chromium",
  "bins": ["chromium"],
  "checkCommand": "chromium --version",
  "detect": {
    "command": "chromium --version",
    "expectExitCode": 0
  },
  "systemPaths": [
    "/Applications/Chromium.app/Contents/MacOS/Chromium",
    "/opt/homebrew/bin/chromium",
    "/usr/bin/chromium",
    "/usr/bin/chromium-browser"
  ],
  "instructions": "Install Chromium with brew install --cask chromium on macOS, or install chromium/chromium-browser on Linux."
}
