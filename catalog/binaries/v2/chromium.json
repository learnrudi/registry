{
  "id": "binary:chromium",
  "kind": "binary",
  "name": "Chromium",
  "version": "131",
  "delivery": "system",
  "install": {
    "source": "system"
  },
  "bins": {
    "chromium": {
      "path": "Chromium.app/Contents/MacOS/Chromium"
    }
  },
  "detect": {
    "command": "chromium --version",
    "expectExitCode": 0
  },
  "meta": {
    "description": "Browser automation for Puppeteer/Playwright",
    "category": "utilities"
  },
  "installHints": {
    "brew": "brew install --cask chromium",
    "apt": "sudo apt install chromium-browser || sudo apt install chromium",
    "manual": "Install Chromium or configure a Playwright-managed Chromium browser before using browser automation tools."
  }
}
