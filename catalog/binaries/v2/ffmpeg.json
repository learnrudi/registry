{
  "id": "binary:ffmpeg",
  "kind": "binary",
  "name": "FFmpeg",
  "version": "7.1",
  "delivery": "system",
  "install": {
    "source": "system"
  },
  "bins": {
    "ffmpeg": {
      "path": "ffmpeg"
    },
    "ffprobe": {
      "path": "ffprobe"
    }
  },
  "detect": {
    "command": "ffmpeg -version",
    "expectExitCode": 0
  },
  "meta": {
    "description": "Audio/video processing toolkit",
    "category": "media",
    "tags": [
      "video",
      "audio",
      "encoding",
      "transcoding"
    ],
    "icon": "🎬"
  },
  "installHints": {
    "brew": "brew install ffmpeg",
    "apt": "sudo apt install ffmpeg",
    "winget": "winget install Gyan.FFmpeg",
    "choco": "choco install ffmpeg",
    "manual": "Install ffmpeg and ffprobe on PATH."
  }
}
