{
  "id": "binary:whisper",
  "kind": "binary",
  "name": "Whisper",
  "version": "1.0.0",
  "delivery": "system",
  "install": {
    "source": "system"
  },
  "bins": {
    "whisper-cli": {
      "path": "bin/whisper-cli"
    }
  },
  "detect": {
    "command": "whisper-cli --version",
    "expectExitCode": 0
  },
  "meta": {
    "description": "OpenAI Whisper speech-to-text (local whisper.cpp)",
    "category": "media"
  },
  "installHints": {
    "brew": "brew install openai-whisper",
    "manual": "Install Whisper with pipx install openai-whisper or uv tool install openai-whisper, and ensure whisper is on PATH."
  }
}
