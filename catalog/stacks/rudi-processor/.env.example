# RUDI Processor Environment Variables
# Copy this file to .env and add only the API keys you want to use
# All LLM providers are OPTIONAL - Stage 1 works without any of these

# ============================================
# STAGE 1 CONFIGURATION (Optional)
# ============================================
# Override default paths if needed
# RUDI_BASE_PATH=/Users/yourname/Documents
# RUDI_PATH=/Users/yourname/Documents/RUDI
# RUDI_INDEX_PATH=/Users/yourname/Documents/Index
# RUDI_OUTPUT_ORGANIZATION=month  # Options: month, date, year, flat

# ============================================
# LLM PROVIDERS (All Optional for Stage 2)
# ============================================
# Only add API keys for providers you want to use
# The system will automatically use available providers

# Anthropic (Claude) - Best for complex reasoning
# Get key from: https://console.anthropic.com/
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY

# OpenAI (GPT) - Best general purpose
# Get key from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Google (Gemini) - Best for long documents
# Get key from: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=YOUR_GOOGLE_API_KEY

# DeepSeek - Best value for code/technical
# Get key from: https://platform.deepseek.com/
# DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY

# ============================================
# OPTIONAL FEATURES
# ============================================
# OCR Support (for image text extraction)
# TESSERACT_PATH=/usr/local/bin/tesseract

# Debug mode
# DEBUG=true

# ============================================
# NOTES
# ============================================
# 1. Stage 1 (Python extraction) works WITHOUT any API keys
# 2. Stage 2 (LLM enhancement) only requires ONE provider minimum
# 3. System auto-selects best available provider
# 4. You can start with zero providers and add them later
# 5. Free tier available for most providers to test
