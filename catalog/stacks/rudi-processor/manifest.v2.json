{
  "id": "stack:rudi-processor",
  "kind": "stack",
  "name": "RUDI Processor",
  "version": "2.0.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/rudi-processor"
  },

  "runtime": "python",
  "requires": {
    "binaries": [
      "ffmpeg",
      "tesseract"
    ],
    "secrets": [
      {
        "key": "ANTHROPIC_API_KEY",
        "label": "Anthropic API Key",
        "required": false
      },
      {
        "key": "OPENAI_API_KEY",
        "label": "OpenAI API Key",
        "required": false
      },
      {
        "key": "GOOGLE_API_KEY",
        "label": "Google API Key",
        "required": false
      },
      {
        "key": "DEEPSEEK_API_KEY",
        "label": "DeepSeek API Key",
        "required": false
      }
    ]
  },
  "provides": {
    "tools": [
      "rudi_process_file",
      "rudi_audit_files",
      "rudi_search_index",
      "rudi_processor_config"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "python3",
    "args": [
      "src/index.py"
    ],
    "cwd": "."
  },

  "meta": {
    "description": "Local file metadata extraction, workspace audit, and indexed content search.",
    "author": "RUDI",
    "license": "MIT",
    "category": "data-extraction",
    "tags": [
      "metadata",
      "files",
      "documents",
      "ocr",
      "indexing",
      "search"
    ],
    "icon": "processor"
  }
}
