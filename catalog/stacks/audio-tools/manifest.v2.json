{
  "id": "stack:audio-tools",
  "kind": "stack",
  "name": "Audio Tools",
  "version": "1.0.0",
  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/audio-tools"
  },
  "runtime": "node",
  "requires": {
    "binaries": [
      "ffmpeg",
      "ffprobe",
      "whisper",
      "yt-dlp"
    ],
    "secrets": []
  },
  "provides": {
    "tools": [
      "audio_transcribe",
      "audio_enrich",
      "audio_query",
      "audio_sync",
      "audio_stats"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": [
      "tsx",
      "src/index.ts"
    ],
    "cwd": "."
  },
  "meta": {
    "description": "Transcribe, enrich, and query audio or video-linked speech. Accepts local files, direct media URLs, supported video-page URLs, or base64 input.",
    "author": "RUDI",
    "license": "MIT",
    "category": "audio-processing",
    "tags": [
      "audio",
      "transcription",
      "whisper",
      "yt-dlp",
      "enrichment",
      "speech-to-text"
    ],
    "icon": "mic"
  }
}
