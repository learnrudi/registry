{
  "id": "stack:audio-tools",
  "name": "Audio Tools",
  "version": "1.0.0",
  "description": "Transcribe, enrich, and query audio or video-linked speech. Accepts local files, direct media URLs, supported video-page URLs, or base64 input.",
  "runtime": "node",
  "command": [
    "npx",
    "tsx",
    "src/index.ts"
  ],
  "provides": {
    "tools": [
      "audio_transcribe",
      "audio_enrich",
      "audio_query",
      "audio_sync",
      "audio_stats"
    ]
  },
  "requires": {
    "binaries": [
      "ffmpeg",
      "ffprobe",
      "whisper",
      "yt-dlp"
    ],
    "secrets": []
  },
  "meta": {
    "author": "RUDI",
    "license": "MIT",
    "category": "audio-processing",
    "tags": [
      "audio",
      "transcription",
      "whisper",
      "yt-dlp",
      "enrichment",
      "speech-to-text"
    ],
    "icon": "🎙️"
  }
}
