{
  "id": "stack:tally",
  "kind": "stack",
  "name": "Tally Forms",
  "version": "1.0.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/tally"
  },

  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "key": "TALLY_API_KEY",
        "label": "Tally API Key",
        "required": true,
        "helpUrl": "https://tally.so/help/api"
      }
    ]
  },
  "provides": {
    "tools": [
      "tally_list_forms",
      "tally_get_form",
      "tally_create_form",
      "tally_update_form",
      "tally_delete_form",
      "tally_list_fields",
      "tally_list_submissions",
      "tally_get_submission",
      "tally_filter_submissions",
      "tally_export_submissions",
      "tally_generate_prefill_url",
      "tally_get_analytics"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["dist/index.js"],
    "cwd": "."
  },

  "meta": {
    "description": "Create, manage, and analyze Tally forms and submissions",
    "author": "RUDI",
    "license": "MIT",
    "category": "productivity",
    "tags": ["tally", "forms", "surveys", "data-collection", "feedback"]
  }
}
