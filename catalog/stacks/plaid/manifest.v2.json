{
  "id": "stack:plaid",
  "kind": "stack",
  "name": "Plaid",
  "version": "0.1.0",
  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/plaid"
  },
  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "key": "PLAID_CLIENT_ID",
        "label": "Plaid Client ID",
        "required": true,
        "helpUrl": "https://dashboard.plaid.com/developers/keys"
      },
      {
        "key": "PLAID_SECRET",
        "label": "Plaid Secret",
        "required": true,
        "helpUrl": "https://dashboard.plaid.com/developers/keys"
      },
      {
        "key": "PLAID_ENV",
        "label": "Plaid Environment",
        "required": false
      },
      {
        "key": "PLAID_TOKEN_STORE_PATH",
        "label": "Plaid Token Store Path",
        "required": false
      }
    ]
  },
  "provides": {
    "tools": [
      "plaid_create_link",
      "plaid_complete_hosted_link",
      "plaid_get_link_status",
      "plaid_exchange_public_token",
      "plaid_list_items",
      "plaid_list_accounts",
      "plaid_get_balances",
      "plaid_sync_transactions"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": [
      "tsx",
      "src/index.ts"
    ],
    "cwd": "."
  },
  "meta": {
    "description": "Connect bank accounts through Plaid, list accounts and balances, and sync transactions.",
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "finance",
    "tags": [
      "plaid",
      "banking",
      "finance",
      "transactions",
      "accounts",
      "balances"
    ]
  }
}
