{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.video-agent/schemas/apply-overlays.schema.json",
  "title": "VideoApplyOverlaysRequest",
  "type": "object",
  "required": [
    "video_path",
    "format",
    "overlays",
    "output_path"
  ],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "video_path": {
      "type": "string",
      "minLength": 1
    },
    "format": {
      "type": "string",
      "enum": [
        "story",
        "portrait",
        "landscape",
        "square"
      ]
    },
    "overlays": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "image_path",
          "start",
          "end"
        ],
        "additionalProperties": false,
        "properties": {
          "image_path": {
            "type": "string",
            "minLength": 1
          },
          "start": {
            "type": "number",
            "minimum": 0
          },
          "end": {
            "type": "number",
            "exclusiveMinimum": 0
          },
          "transition": {
            "type": "string",
            "enum": [
              "fade",
              "cut"
            ]
          },
          "show_pip": {
            "type": "boolean"
          }
        }
      }
    },
    "presenter_pip": {
      "type": "object",
      "required": [
        "enabled"
      ],
      "additionalProperties": false,
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "shape": {
          "type": "string",
          "enum": [
            "circle"
          ]
        },
        "size": {
          "type": "integer",
          "exclusiveMinimum": 0
        },
        "position": {
          "type": "string",
          "enum": [
            "top-right",
            "top-left",
            "bottom-right",
            "bottom-left"
          ]
        },
        "margin": {
          "type": "integer",
          "minimum": 0
        },
        "show": {
          "type": "string",
          "enum": [
            "during_overlays"
          ]
        },
        "crop": {
          "type": "object",
          "required": [
            "x",
            "y",
            "width",
            "height"
          ],
          "additionalProperties": false,
          "properties": {
            "x": {
              "type": "integer",
              "minimum": 0
            },
            "y": {
              "type": "integer",
              "minimum": 0
            },
            "width": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "height": {
              "type": "integer",
              "exclusiveMinimum": 0
            }
          }
        }
      }
    },
    "output_path": {
      "type": "string",
      "minLength": 1
    },
    "presenter_pip": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "shape": { "type": "string", "enum": ["circle", "square"] },
        "size": { "type": "integer", "exclusiveMinimum": 0 },
        "position": {
          "type": "string",
          "enum": ["top-right", "top-left", "bottom-right", "bottom-left"]
        },
        "margin": { "type": "integer", "minimum": 0 },
        "show": {
          "type": "string",
          "enum": ["during_overlays", "always", "never"]
        },
        "exclude_overlay_indexes": {
          "type": "array",
          "items": { "type": "integer", "minimum": 0 }
        },
        "crop": {
          "type": "object",
          "required": ["x", "y", "width", "height"],
          "additionalProperties": false,
          "properties": {
            "x": { "type": "integer", "minimum": 0 },
            "y": { "type": "integer", "minimum": 0 },
            "width": { "type": "integer", "exclusiveMinimum": 0 },
            "height": { "type": "integer", "exclusiveMinimum": 0 }
          }
        }
      }
    }
  }
}
