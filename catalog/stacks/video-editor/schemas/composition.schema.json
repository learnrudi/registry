{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.video-agent/schemas/composition.schema.json",
  "title": "VideoAgentComposition",
  "type": "object",
  "required": ["schemaVersion", "projectSlug", "source", "timeline"],
  "additionalProperties": false,
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "projectSlug": { "type": "string", "minLength": 1 },
    "source": {
      "type": "object",
      "required": ["path", "fps"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "fps": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "timeline": {
      "type": "object",
      "required": ["keepRanges", "audioCrossfadeSeconds", "captions", "textOverlays", "punchIns"],
      "additionalProperties": false,
      "properties": {
        "keepRanges": {
          "type": "array",
          "items": { "$ref": "#/$defs/timeRange" }
        },
        "audioCrossfadeSeconds": { "type": "number", "minimum": 0 },
        "captions": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "source": { "type": "string", "minLength": 1 },
            "style": { "type": "string", "minLength": 1 },
            "cues": {
              "type": "array",
              "items": { "$ref": "#/$defs/captionCue" }
            }
          }
        },
        "watermark": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "text": { "type": "string" }
          }
        },
        "grade": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": { "type": "boolean" },
            "preset": { "type": "string", "enum": ["natural", "talking-head", "punchy"] },
            "source": { "type": "string", "minLength": 1 },
            "filter": { "type": "string", "minLength": 1 },
            "lut": { "type": "string", "minLength": 1 },
            "exposure": { "type": "number", "minimum": -3, "maximum": 3 },
            "black": { "type": "number", "minimum": -1, "maximum": 1 },
            "brightness": { "type": "number", "minimum": -1, "maximum": 1 },
            "contrast": { "type": "number", "exclusiveMinimum": 0, "maximum": 3 },
            "saturation": { "type": "number", "minimum": 0, "maximum": 3 },
            "gamma": { "type": "number", "exclusiveMinimum": 0, "maximum": 3 },
            "vibrance": { "type": "number", "minimum": -2, "maximum": 2 },
            "sharpen": { "type": "number", "minimum": -2, "maximum": 5 }
          }
        },
        "textOverlays": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["at", "duration", "text"],
            "additionalProperties": false,
            "properties": {
              "at": { "type": "number", "minimum": 0 },
              "duration": { "type": "number", "exclusiveMinimum": 0 },
              "text": { "type": "string", "minLength": 1 },
              "position": { "type": "string", "enum": ["top", "top-left", "bottom"] },
              "size": { "type": "string", "enum": ["small", "default"] }
            }
          }
        },
        "punchIns": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["at", "duration", "scale"],
            "additionalProperties": false,
            "properties": {
              "at": { "type": "number", "minimum": 0 },
              "duration": { "type": "number", "exclusiveMinimum": 0 },
              "scale": { "type": "number", "exclusiveMinimum": 1 }
            }
          }
        },
        "chapters": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["at", "title"],
            "additionalProperties": false,
            "properties": {
              "at": { "type": "number", "minimum": 0 },
              "title": { "type": "string", "minLength": 1 }
            }
          }
        },
        "insights": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["at", "duration", "title"],
            "additionalProperties": false,
            "properties": {
              "at": { "type": "number", "minimum": 0 },
              "duration": { "type": "number", "exclusiveMinimum": 0 },
              "title": { "type": "string", "minLength": 1 },
              "body": { "type": "string" },
              "tag": { "type": "string" }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "timeRange": {
      "type": "object",
      "required": ["start", "end"],
      "additionalProperties": false,
      "properties": {
        "start": { "type": "number", "minimum": 0 },
        "end": { "type": "number", "exclusiveMinimum": 0 },
        "speed": { "type": "number", "minimum": 0.25, "maximum": 16, "default": 1 }
      }
    },
    "captionCue": {
      "type": "object",
      "required": ["at", "duration", "text"],
      "additionalProperties": true,
      "properties": {
        "at": { "type": "number", "minimum": 0 },
        "duration": { "type": "number", "exclusiveMinimum": 0 },
        "text": { "type": "string", "minLength": 1 }
      }
    }
  }
}
