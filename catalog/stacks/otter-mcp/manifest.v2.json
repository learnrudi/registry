{
  "id": "stack:otter-mcp",
  "kind": "stack",
  "name": "Otter MCP",
  "version": "0.1.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/otter-mcp"
  },

  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": []
  },
  "provides": {
    "tools": [
      "get_user_info",
      "search",
      "fetch"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": [
      "src/index.js"
    ],
    "cwd": "."
  },

  "meta": {
    "description": "Search and fetch Otter meeting transcripts through Otter's hosted OAuth MCP server.",
    "author": "RUDI",
    "license": "MIT",
    "category": "productivity",
    "tags": [
      "otter",
      "meetings",
      "transcripts",
      "mcp",
      "oauth"
    ],
    "icon": "otter"
  }
}
