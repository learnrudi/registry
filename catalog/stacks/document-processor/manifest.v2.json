{
  "id": "stack:document-processor",
  "kind": "stack",
  "name": "Document Processor",
  "version": "1.0.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/document-processor"
  },

  "runtime": "python",
  "requires": {
    "binaries": ["pdftoppm"],
    "secrets": []
  },
  "provides": {
    "tools": [
      "pdf_to_images",
      "remove_watermark",
      "pdf_extract_slides",
      "batch_remove_watermark"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "python3",
    "args": ["src/index.py"],
    "cwd": "."
  },

  "meta": {
    "description": "Extract PDF slides as images, remove watermarks, and process presentations.",
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "document-processing",
    "tags": ["pdf", "slides", "watermark", "extraction", "images", "presentation"],
    "icon": "📄"
  }
}
