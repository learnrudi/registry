{
  "name": "social-media-publisher",
  "version": "1.0.0",
  "description": "Social media MCP and unified publisher core",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "npx tsx src/index.ts",
    "build": "tsc",
    "test": "node --import tsx --test",
    "api": "node src/api/server.js",
    "db:migrate": "node src/db/migrate.js",
    "db:check": "node src/db/check.js",
    "import:meta": "node scripts/import-meta-config.js",
    "import:linkedin": "node scripts/import-linkedin-token.js",
    "linkedin:login": "node scripts/linkedin-oauth-login.js",
    "import:twitter": "node scripts/import-twitter-token.js",
    "import:youtube": "node scripts/import-youtube-token.js",
    "meta:login": "node scripts/meta-oauth-login.js",
    "youtube:login": "node scripts/youtube-oauth-login.js",
    "publish-worker": "node scripts/process-publish-jobs.js",
    "publish-worker:once": "node scripts/process-publish-jobs.js --once",
    "smoke:publish-dry-run": "node scripts/smoke-unified-publish.js"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "axios": "^1.16.1",
    "dotenv": "^17.2.3",
    "form-data": "^4.0.5",
    "hono": "^4.12.18",
    "pg": "^8.20.0",
    "twitter-api-v2": "^1.27.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  },
  "overrides": {
    "ajv": "^8.20.0",
    "fast-uri": "^3.1.2"
  }
}
