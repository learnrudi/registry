{
  "id": "stack:social-media-publisher",
  "kind": "stack",
  "name": "Social Media Publisher",
  "version": "1.0.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/social-media-publisher"
  },

  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": [
      { "key": "TWITTER_API_KEY", "label": "Twitter API Key", "required": false },
      { "key": "TWITTER_API_SECRET", "label": "Twitter API Secret", "required": false },
      { "key": "TWITTER_ACCESS_TOKEN", "label": "Twitter Access Token", "required": false },
      { "key": "TWITTER_ACCESS_SECRET", "label": "Twitter Access Secret", "required": false },
      { "key": "TWITTER_OAUTH2_ACCESS_TOKEN", "label": "Twitter OAuth2 Access Token", "required": false },
      { "key": "TWITTER_OAUTH2_REFRESH_TOKEN", "label": "Twitter OAuth2 Refresh Token", "required": false },
      { "key": "TWITTER_OAUTH2_CLIENT_ID", "label": "Twitter OAuth2 Client ID", "required": false },
      { "key": "TWITTER_OAUTH2_CLIENT_SECRET", "label": "Twitter OAuth2 Client Secret", "required": false },
      { "key": "TWITTER_OAUTH2_TOKEN_URI", "label": "Twitter OAuth2 Token URI", "required": false },
      { "key": "LINKEDIN_CLIENT_ID", "label": "LinkedIn Client ID", "required": false },
      { "key": "LINKEDIN_CLIENT_SECRET", "label": "LinkedIn Client Secret", "required": false },
      { "key": "LINKEDIN_ACCESS_TOKEN", "label": "LinkedIn Access Token", "required": false },
      { "key": "LINKEDIN_ACCESS_TOKEN_EXPIRES_AT", "label": "LinkedIn Access Token Expires At", "required": false },
      { "key": "LINKEDIN_REFRESH_TOKEN", "label": "LinkedIn Refresh Token", "required": false },
      { "key": "LINKEDIN_TOKEN_URI", "label": "LinkedIn Token URI", "required": false },
      { "key": "LINKEDIN_REDIRECT_URI", "label": "LinkedIn Redirect URI", "required": false },
      { "key": "LINKEDIN_SCOPES", "label": "LinkedIn OAuth Scopes", "required": false },
      { "key": "DATABASE_URL", "label": "Database URL", "required": false },
      { "key": "DIRECT_DATABASE_URL", "label": "Direct Database URL", "required": false },
      { "key": "INTERNAL_API_KEY", "label": "Internal API Key", "required": false },
      { "key": "TOKEN_ENCRYPTION_KEY", "label": "Token Encryption Key", "required": false },
      { "key": "META_APP_ID", "label": "Meta App ID", "required": false },
      { "key": "META_APP_SECRET", "label": "Meta App Secret", "required": false },
      { "key": "META_REDIRECT_URI", "label": "Meta Redirect URI", "required": false },
      { "key": "META_SCOPES", "label": "Meta OAuth Scopes", "required": false },
      { "key": "META_USER_ACCESS_TOKEN", "label": "Meta User Access Token", "required": false },
      { "key": "META_INSTAGRAM_APP_ID", "label": "Meta Instagram App ID", "required": false },
      { "key": "META_INSTAGRAM_APP_SECRET", "label": "Meta Instagram App Secret", "required": false },
      { "key": "GOOGLE_CLIENT_ID", "label": "Google Client ID", "required": false },
      { "key": "GOOGLE_CLIENT_SECRET", "label": "Google Client Secret", "required": false },
      { "key": "YOUTUBE_REFRESH_TOKEN", "label": "YouTube Refresh Token", "required": false },
      { "key": "YOUTUBE_TOKEN_URI", "label": "YouTube Token URI", "required": false },
      { "key": "YOUTUBE_SCOPES", "label": "YouTube Scopes", "required": false },
      { "key": "TIKTOK_ACCESS_TOKEN", "label": "TikTok Access Token", "required": false },
      { "key": "TIKTOK_REFRESH_TOKEN", "label": "TikTok Refresh Token", "required": false },
      { "key": "TIKTOK_CLIENT_KEY", "label": "TikTok Client Key", "required": false },
      { "key": "TIKTOK_CLIENT_SECRET", "label": "TikTok Client Secret", "required": false },
      { "key": "TIKTOK_REDIRECT_URI", "label": "TikTok Redirect URI", "required": false },
      { "key": "TIKTOK_SCOPE", "label": "TikTok Scope", "required": false }
    ]
  },
  "provides": {
    "tools": ["social_list_supported_platforms", "social_validate_post", "social_check_publish_ready", "social_publish_direct", "twitter_post", "twitter_thread", "linkedin_post", "facebook_post", "facebook_list_pages", "instagram_post", "instagram_list_accounts", "tiktok_creator_info", "tiktok_direct_post", "tiktok_video_upload", "tiktok_fetch_status", "youtube_video_upload"]
  },
  "related": {
    "skills": [
      "skill:shortform-publish-copy"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": ["tsx", "src/index.ts"],
    "cwd": "."
  },

  "meta": {
    "description": "Post to Twitter, LinkedIn, Facebook, Instagram, TikTok, and YouTube with readiness checks and unified publisher validation",
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "social",
    "tags": ["twitter", "linkedin", "facebook", "instagram", "tiktok", "youtube", "social-media"],
    "icon": "📱"
  }
}
