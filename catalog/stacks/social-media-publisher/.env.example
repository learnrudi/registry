# Social Media - Environment Variables
# Copy to .env and fill in your values

# Twitter/X API credentials (optional)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_OAUTH2_ACCESS_TOKEN=
TWITTER_OAUTH2_REFRESH_TOKEN=
TWITTER_OAUTH2_CLIENT_ID=
TWITTER_OAUTH2_CLIENT_SECRET=
TWITTER_OAUTH2_TOKEN_URI=

# LinkedIn credentials (optional)
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ACCESS_TOKEN_EXPIRES_AT=
LINKEDIN_REFRESH_TOKEN=
LINKEDIN_TOKEN_URI=
LINKEDIN_REDIRECT_URI=
LINKEDIN_SCOPES=

# Unified publisher API and worker (optional)
DATABASE_URL=
DIRECT_DATABASE_URL=
INTERNAL_API_KEY=
TOKEN_ENCRYPTION_KEY=

# Meta/Facebook/Instagram publishing (optional)
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_SCOPES=
META_USER_ACCESS_TOKEN=
META_INSTAGRAM_APP_ID=
META_INSTAGRAM_APP_SECRET=

# YouTube publishing (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
YOUTUBE_REFRESH_TOKEN=
YOUTUBE_TOKEN_URI=
YOUTUBE_SCOPES=

# TikTok publishing (optional)
TIKTOK_ACCESS_TOKEN=
TIKTOK_REFRESH_TOKEN=
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=
TIKTOK_SCOPE=
