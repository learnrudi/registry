{
  "id": "stack:twilio-sms",
  "kind": "stack",
  "name": "Twilio SMS",
  "version": "0.1.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/twilio-sms"
  },

  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "key": "TWILIO_ACCOUNT_SID",
        "label": "Twilio Account SID",
        "required": true,
        "helpUrl": "https://console.twilio.com/"
      },
      {
        "key": "TWILIO_AUTH_TOKEN",
        "label": "Twilio Auth Token",
        "required": false,
        "helpUrl": "https://console.twilio.com/"
      },
      {
        "key": "TWILIO_API_KEY_SID",
        "label": "Twilio API Key SID",
        "required": false,
        "helpUrl": "https://console.twilio.com/us1/account/keys-credentials/api-keys"
      },
      {
        "key": "TWILIO_API_KEY_SECRET",
        "label": "Twilio API Key Secret",
        "required": false,
        "helpUrl": "https://console.twilio.com/us1/account/keys-credentials/api-keys"
      },
      {
        "key": "TWILIO_FROM_NUMBER",
        "label": "Twilio From Number",
        "required": false,
        "helpUrl": "https://console.twilio.com/us1/develop/phone-numbers/manage/incoming"
      },
      {
        "key": "TWILIO_MESSAGING_SERVICE_SID",
        "label": "Twilio Messaging Service SID",
        "required": false,
        "helpUrl": "https://console.twilio.com/us1/develop/sms/services"
      }
    ]
  },
  "provides": {
    "tools": [
      "twilio_config_status",
      "twilio_send_sms",
      "twilio_list_messages",
      "twilio_get_message"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": ["tsx", "src/index.ts"],
    "cwd": "."
  },

  "meta": {
    "description": "Send SMS messages and inspect recent Twilio messages through a guarded MCP interface.",
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "communication",
    "tags": ["twilio", "sms", "messaging", "mcp", "communication"],
    "icon": "💬"
  }
}
