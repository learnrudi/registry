{
  "name": "@rudi/twilio-sms-stack",
  "version": "0.1.0",
  "description": "RUDI MCP stack for sending and inspecting Twilio SMS messages.",
  "type": "module",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
