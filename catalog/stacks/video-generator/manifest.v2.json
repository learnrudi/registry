{
  "id": "stack:video-generator",
  "kind": "stack",
  "name": "Video Generator",
  "version": "0.1.0",
  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/video-generator"
  },
  "runtime": "python",
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "key": "GEMINI_API_KEY",
        "label": "Gemini API key",
        "required": false,
        "helpUrl": "https://aistudio.google.com/apikey"
      },
      {
        "key": "REPLICATE_API_TOKEN",
        "label": "Replicate API token",
        "required": false,
        "helpUrl": "https://replicate.com/account/api-tokens"
      },
      {
        "key": "FAL_KEY",
        "label": "fal API key",
        "required": false,
        "helpUrl": "https://fal.ai/dashboard/keys"
      },
      {
        "key": "OPENAI_API_KEY",
        "label": "OpenAI API key",
        "required": false,
        "helpUrl": "https://platform.openai.com/api-keys"
      }
    ]
  },
  "provides": {
    "tools": [
      "list_video_models",
      "generate_video",
      "get_video_job"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "python",
    "args": [
      "src/server.py"
    ],
    "cwd": "."
  },
  "meta": {
    "description": "Agent-safe multi-provider video generation for content creation workflows.",
    "author": "brandonz@heritagehill.co",
    "license": "MIT",
    "category": "ai-generation",
    "tags": [
      "video",
      "generation",
      "ai",
      "gemini",
      "veo",
      "replicate",
      "fal",
      "openai",
      "sora",
      "content-creation",
      "social-media"
    ],
    "icon": "video"
  }
}
