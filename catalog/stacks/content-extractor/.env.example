# Content Extractor - Environment Variables
# Copy to .env and fill in your values

# Optional but recommended - Supadata API for reliable YouTube transcript extraction.
# Without this, YouTube falls back to public no-key methods that may return
# metadata without a transcript when YouTube blocks or changes caption access.
# Get yours: https://supadata.ai
SUPA_DATA_API=

# Optional - Reddit OAuth fallback. Reddit extraction works without credentials
# by falling back from public JSON to old Reddit HTML when available.
# Use either REDDIT_BEARER_TOKEN or both REDDIT_CLIENT_ID and REDDIT_CLIENT_SECRET
# only if you want authenticated API fallback.
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_BEARER_TOKEN=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
