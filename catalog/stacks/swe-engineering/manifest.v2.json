{
  "id": "stack:swe-engineering",
  "kind": "stack",
  "name": "SWE Engineering",
  "version": "0.1.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/swe-engineering"
  },

  "runtime": "node",

  "requires": {
    "binaries": [],
    "secrets": []
  },

  "provides": {
    "tools": [
      "swe_manual_list",
      "swe_manual_read",
      "swe_manual_search",
      "swe_debt_scan"
    ]
  },

  "related": {
    "skills": [
      "skill:swe-compliance-checklist"
    ]
  },

  "mcp": {
    "transport": "stdio",
    "command": "node",
    "args": ["src/index.js"],
    "cwd": "."
  },

  "meta": {
    "description": "Portable SWE Operating Manual reference and JS/TS agent debt scanning tools for engineering workflows.",
    "author": "RUDI",
    "license": "MIT",
    "category": "development",
    "tags": ["swe", "engineering", "manual", "testing", "debugging", "debt-scan", "code-quality"]
  }
}
