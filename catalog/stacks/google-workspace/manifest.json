{
  "id": "google-workspace",
  "name": "Google Workspace Tools",
  "version": "1.0.0",
  "description": "Workflow-focused tools for Gmail, Google Sheets, Docs, Slides, Drive, Calendar, and Tasks. Draft emails, send from markdown files, manage spreadsheets, create tasks, and more.",
  "runtime": "node",
  "command": [
    "npx",
    "tsx",
    "src/index.ts"
  ],
  "requiresAuth": true,
  "authCommand": "rudi auth google-workspace user@example.com",
  "authInstructions": "Run `rudi secrets set GOOGLE_CREDENTIALS` with Google OAuth client credentials JSON or a path to credentials.json, then run `rudi auth google-workspace user@example.com`. Register the localhost OAuth callback URI used by the helper, normally http://localhost:3456/callback, and any fallback ports you expect to use. Tokens are stored under ~/.rudi/state/stacks/google-workspace/accounts/<account>/token.json.",
  "provides": {
    "tools": [
      "account_list",
      "account_switch",
      "account_current",
      "gmail_profile",
      "gmail_send",
      "gmail_search",
      "gmail_draft",
      "gmail_draft_list",
      "gmail_draft_get",
      "gmail_draft_update",
      "gmail_draft_delete",
      "gmail_draft_send",
      "gmail_get",
      "gmail_list_attachments",
      "gmail_get_attachment",
      "gmail_reply",
      "gmail_forward",
      "gmail_get_thread",
      "gmail_message_trash",
      "gmail_message_untrash",
      "gmail_message_delete",
      "gmail_label_list",
      "gmail_label_create",
      "gmail_label_update",
      "gmail_label_delete",
      "gmail_message_modify_labels",
      "gmail_message_archive",
      "gmail_message_mark_read",
      "gmail_message_mark_unread",
      "gmail_message_star",
      "gmail_message_unstar",
      "gmail_message_batch_get",
      "gmail_thread_batch_get",
      "gmail_message_batch_modify_labels",
      "gmail_message_batch_trash",
      "gmail_message_batch_untrash",
      "gmail_message_batch_delete",
      "sheets_read",
      "sheets_write",
      "sheets_append",
      "sheets_create",
      "docs_read",
      "docs_create",
      "docs_insert_image",
      "drive_list",
      "drive_upload",
      "drive_create_folder",
      "drive_move_file",
      "drive_download",
      "drive_make_public",
      "drive_delete",
      "calendar_list",
      "calendar_create",
      "calendar_quick_add",
      "calendar_delete",
      "tasks_tasklists_list",
      "tasks_list",
      "tasks_create",
      "tasks_update",
      "tasks_complete",
      "tasks_delete"
    ]
  },
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "description": "OAuth 2.0 credentials.json from Google Cloud Console",
        "label": "Google OAuth Credentials",
        "link": "https://console.cloud.google.com/apis/credentials",
        "name": "GOOGLE_CREDENTIALS"
      }
    ]
  },
  "meta": {
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "api-integrations",
    "tags": [
      "google",
      "gmail",
      "sheets",
      "docs",
      "drive",
      "calendar",
      "slides",
      "email",
      "automation",
      "workspace",
      "tasks"
    ],
    "icon": "📧"
  },
  "inputs": [
    {
      "name": "action",
      "type": "string",
      "description": "Action to perform",
      "required": true,
      "options": [
        "draft_email",
        "send_email",
        "reply",
        "read_sheet",
        "write_sheet",
        "create_doc",
        "upload_drive"
      ]
    },
    {
      "name": "to",
      "type": "string",
      "description": "Recipient name or email (for email actions)",
      "required": false
    },
    {
      "name": "subject",
      "type": "string",
      "description": "Email subject",
      "required": false
    },
    {
      "name": "body",
      "type": "string",
      "description": "Email body or file path",
      "required": false
    },
    {
      "name": "spreadsheet_id",
      "type": "string",
      "description": "Google Sheets spreadsheet ID",
      "required": false
    },
    {
      "name": "range",
      "type": "string",
      "description": "Sheet range (e.g., Sheet1!A1:B10)",
      "required": false
    }
  ],
  "outputs": [
    {
      "name": "result",
      "type": "string",
      "description": "Operation result or data"
    },
    {
      "name": "id",
      "type": "string",
      "description": "Created resource ID (email, doc, file)"
    }
  ],
  "dependencies": {
    "python": ">=3.8"
  }
}
