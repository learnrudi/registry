{
  "id": "stack:google-workspace",
  "kind": "stack",
  "name": "Google Workspace Tools",
  "version": "1.0.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/google-workspace"
  },

  "auth": {
    "required": true,
    "command": "rudi auth google-workspace user@example.com",
    "instructions": "Run `rudi secrets set GOOGLE_CREDENTIALS` with Google OAuth client credentials JSON or a path to credentials.json, then run `rudi auth google-workspace user@example.com`. Register the localhost OAuth callback URI used by the helper, normally http://localhost:3456/callback, and any fallback ports you expect to use. Tokens are stored under ~/.rudi/state/stacks/google-workspace/accounts/<account>/token.json."
  },

  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "key": "GOOGLE_CREDENTIALS",
        "label": "Google OAuth Credentials",
        "required": true,
        "helpUrl": "https://console.cloud.google.com/apis/credentials"
      }
    ]
  },
  "provides": {
    "tools": [
      "account_list",
      "account_switch",
      "account_current",
      "gmail_profile",
      "gmail_send",
      "gmail_search",
      "gmail_draft",
      "gmail_draft_list",
      "gmail_draft_get",
      "gmail_draft_update",
      "gmail_draft_delete",
      "gmail_draft_send",
      "gmail_get",
      "gmail_list_attachments",
      "gmail_get_attachment",
      "gmail_reply",
      "gmail_forward",
      "gmail_get_thread",
      "gmail_message_trash",
      "gmail_message_untrash",
      "gmail_message_delete",
      "gmail_label_list",
      "gmail_label_create",
      "gmail_label_update",
      "gmail_label_delete",
      "gmail_message_modify_labels",
      "gmail_message_archive",
      "gmail_message_mark_read",
      "gmail_message_mark_unread",
      "gmail_message_star",
      "gmail_message_unstar",
      "gmail_message_batch_get",
      "gmail_thread_batch_get",
      "gmail_message_batch_modify_labels",
      "gmail_message_batch_trash",
      "gmail_message_batch_untrash",
      "gmail_message_batch_delete",
      "sheets_read",
      "sheets_write",
      "sheets_append",
      "sheets_create",
      "docs_read",
      "docs_create",
      "docs_insert_image",
      "drive_list",
      "drive_upload",
      "drive_create_folder",
      "drive_move_file",
      "drive_download",
      "drive_make_public",
      "drive_delete",
      "calendar_list",
      "calendar_create",
      "calendar_quick_add",
      "calendar_delete",
      "tasks_tasklists_list",
      "tasks_list",
      "tasks_create",
      "tasks_update",
      "tasks_complete",
      "tasks_delete"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": ["tsx", "src/index.ts"],
    "cwd": "."
  },

  "meta": {
    "description": "Workflow-focused tools for Gmail, Google Sheets, Docs, Slides, Drive, Calendar, and Tasks",
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "api-integrations",
    "tags": ["google", "gmail", "sheets", "docs", "drive", "calendar", "tasks"],
    "icon": "📧"
  }
}
