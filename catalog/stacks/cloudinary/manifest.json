{
  "id": "cloudinary",
  "name": "Cloudinary",
  "version": "0.1.0",
  "description": "Upload local media to Cloudinary and return public HTTPS URLs for social publishing workflows.",
  "runtime": "node",
  "command": [
    "npx",
    "tsx",
    "src/index.ts"
  ],
  "provides": {
    "tools": [
      "cloudinary_config_status",
      "cloudinary_upload_video",
      "cloudinary_get_resource"
    ]
  },
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "name": "CLOUDINARY_CLOUD_NAME",
        "label": "Cloudinary Cloud Name",
        "description": "Cloudinary product environment cloud name.",
        "required": false,
        "link": "https://cloudinary.com/documentation/cloudinary_credentials"
      },
      {
        "name": "CLOUDINARY_API_KEY",
        "label": "Cloudinary API Key",
        "description": "Cloudinary API key for signed server-side uploads.",
        "required": false,
        "link": "https://cloudinary.com/documentation/cloudinary_credentials"
      },
      {
        "name": "CLOUDINARY_API_SECRET",
        "label": "Cloudinary API Secret",
        "description": "Cloudinary API secret for signed server-side uploads.",
        "required": false,
        "link": "https://cloudinary.com/documentation/cloudinary_credentials"
      },
      {
        "name": "CLOUDINARY_URL",
        "label": "Cloudinary URL",
        "description": "Optional combined Cloudinary credential URL.",
        "required": false,
        "link": "https://cloudinary.com/documentation/cloudinary_credentials"
      }
    ]
  },
  "meta": {
    "author": "RUDI",
    "license": "MIT",
    "category": "media",
    "tags": [
      "cloudinary",
      "video",
      "media",
      "upload",
      "shortform",
      "social-media"
    ],
    "icon": "cloud-upload"
  }
}
