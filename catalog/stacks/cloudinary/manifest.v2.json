{
  "id": "stack:cloudinary",
  "kind": "stack",
  "name": "Cloudinary",
  "version": "0.1.0",
  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/cloudinary"
  },
  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "key": "CLOUDINARY_CLOUD_NAME",
        "label": "Cloudinary Cloud Name",
        "required": false,
        "helpUrl": "https://cloudinary.com/documentation/cloudinary_credentials"
      },
      {
        "key": "CLOUDINARY_API_KEY",
        "label": "Cloudinary API Key",
        "required": false,
        "helpUrl": "https://cloudinary.com/documentation/cloudinary_credentials"
      },
      {
        "key": "CLOUDINARY_API_SECRET",
        "label": "Cloudinary API Secret",
        "required": false,
        "helpUrl": "https://cloudinary.com/documentation/cloudinary_credentials"
      },
      {
        "key": "CLOUDINARY_URL",
        "label": "Cloudinary URL",
        "required": false,
        "helpUrl": "https://cloudinary.com/documentation/cloudinary_credentials"
      }
    ]
  },
  "provides": {
    "tools": [
      "cloudinary_config_status",
      "cloudinary_upload_video",
      "cloudinary_get_resource"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": [
      "tsx",
      "src/index.ts"
    ],
    "cwd": "."
  },
  "meta": {
    "description": "Upload local media to Cloudinary and return public HTTPS URLs for social publishing workflows.",
    "author": "RUDI",
    "license": "MIT",
    "category": "media",
    "tags": [
      "cloudinary",
      "video",
      "media",
      "upload",
      "shortform",
      "social-media"
    ],
    "icon": "cloud-upload"
  }
}
