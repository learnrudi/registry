{
  "name": "web-export-mcp",
  "version": "2.0.0",
  "description": "Web Export MCP - HTML to PNG/PDF with artifact verification",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node ./node_modules/tsx/dist/cli.mjs src/index.ts",
    "build": "node ./node_modules/typescript/bin/tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "npm run build && node --test test/**/*.test.mjs",
    "install-browser": "playwright install chromium"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "dotenv": "^16.3.1",
    "playwright": "^1.40.0",
    "pdf-lib": "^1.17.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.3.0"
  }
}
