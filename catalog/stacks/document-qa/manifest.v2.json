{
  "id": "stack:document-qa",
  "kind": "stack",
  "name": "Document QA",
  "version": "1.0.0",

  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/document-qa"
  },

  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": [
      {
        "key": "ANTHROPIC_API_KEY",
        "label": "Anthropic API Key",
        "required": true,
        "helpUrl": "https://console.anthropic.com/settings/keys"
      }
    ]
  },
  "provides": {
    "tools": [
      "document_qa_inspect"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": ["tsx", "src/index.ts"],
    "cwd": "."
  },

  "meta": {
    "description": "Visual QA inspection for HTML documents using screenshots and Claude Vision.",
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "document-processing",
    "tags": ["qa", "vision", "html", "pdf", "validation"],
    "icon": "🔍"
  }
}
