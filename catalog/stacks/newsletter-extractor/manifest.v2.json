{
  "id": "stack:newsletter-extractor",
  "kind": "stack",
  "name": "Newsletter Extractor",
  "version": "0.1.0",
  "delivery": "remote",
  "install": {
    "source": "catalog",
    "path": "catalog/stacks/newsletter-extractor"
  },
  "runtime": "node",
  "requires": {
    "binaries": [],
    "secrets": []
  },
  "provides": {
    "tools": [
      "extract_newsletter_email",
      "extract_newsletter_links",
      "extract_rss_feed"
    ]
  },
  "mcp": {
    "transport": "stdio",
    "command": "npx",
    "args": [
      "tsx",
      "src/index.ts"
    ],
    "cwd": "."
  },
  "meta": {
    "description": "Extract newsletter email bodies, normalize newsletter links, and read RSS/Atom feeds",
    "author": "CO-LLAB",
    "license": "MIT",
    "category": "data-extraction",
    "tags": [
      "newsletter",
      "email",
      "gmail",
      "rss",
      "atom",
      "links",
      "extraction",
      "content"
    ],
    "icon": "📬"
  }
}
